        <form id="newsletterForm" onsubmit="submitNewsletter(event)">
          <div class="form-group">
            <label class="form-label" for="newsletter-name">Full Name</label>
            <input class="form-input" id="newsletter-name" name="name" type="text" placeholder="Enter your full name" required />
