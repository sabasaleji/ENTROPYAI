              <div class="form-group">
                <label class="form-label" for="email">Email Address</label>
                <input class="form-input" id="email" name="email" type="email" placeholder="you@company.com" required />
              </div>

              <button class="btn-primary" type="submit" style="width: 100%; margin-bottom: 16px;">
                <span>Reserve My Spot</span>
              </button>
            </form>

            <div class="form-footer">
              Have questions? Email us at <a href="mailto:services@entropy-ai.in">services@entropy-ai.in</a>
            </div>
          </div>
        </div>
