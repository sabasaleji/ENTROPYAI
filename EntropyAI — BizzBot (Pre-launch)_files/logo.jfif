  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div>
          <div class="logo" style="margin-bottom: 16px;">
            <img src="logo.jfif" alt="EntropyAI logo" onerror="this.style.display='none'" />
